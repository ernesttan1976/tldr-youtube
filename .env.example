OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Transcript ASR provider: openai | local
ASR_PROVIDER=openai
ASR_LANGUAGE=en

# Local ASR (faster-whisper) defaults.
LOCAL_ASR_MODEL=small.en
LOCAL_ASR_DEVICE=cpu
LOCAL_ASR_COMPUTE_TYPE=int8

# Optional: restrict CORS to your extension id once installed.
# Example: ALLOW_ORIGINS=chrome-extension://<your-extension-id>
ALLOW_ORIGINS=*
